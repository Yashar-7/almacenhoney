# Copiá este archivo como "keystore.properties" en esta misma carpeta (android/)
# y poné el archivo .jks junto a android/app/build.gradle con el nombre que indiques aquí.
#
# NO subas keystore.properties ni el .jks al repositorio.

storeFile=release-upload.jks
storePassword=TU_STORE_PASSWORD
keyAlias=TU_ALIAS
keyPassword=TU_KEY_PASSWORD
